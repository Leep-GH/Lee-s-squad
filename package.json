{
  "name": "lees-squad",
  "version": "1.0.0",
  "private": true,
  "description": "Lee's Squad — PRD-driven AI build team",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/squad-sdk && npm run build -w packages/squad-cli",
    "lint": "tsc --noEmit -p packages/squad-sdk/tsconfig.json && tsc --noEmit -p packages/squad-cli/tsconfig.json"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "copilot",
    "multi-agent",
    "squad",
    "sdk"
  ],
  "license": "MIT"
}
